@@ -0,0 +1,93 @@
+/* ScummVM dgds CJK localization support (Rise of the Dragon CHT).
+ * Non-upstream: engine-side translation overlay + Big5 bitmap font + language switch.
+ */
+
+#ifndef DGDS_CJK_H
+#define DGDS_CJK_H
+
+#include "common/str.h"
+#include "common/hashmap.h"
+#include "common/hash-str.h"
+#include "common/array.h"
+#include "graphics/managed_surface.h"
+#include "graphics/font.h"
+
+namespace Dgds {
+
+class DgdsFont;
+
+// Big5 linear index: (lead-0x81)*157 + trailoffset; matches tools/build_cjk_font.py
+int big5LinearIndex(byte lead, byte trail);
+
+enum CJKLang { kCJKLangOrig = 0, kCJKLangZH = 1, kCJKLangJA = 2 };
+
+class CJKSupport {
+public:
+	CJKSupport();
+	~CJKSupport();
+
+	// Load DCJK bitmap font + DTRN translation pack (searched via Common::File).
+	bool load(const Common::String &fontFile, const Common::String &trnFile);
+	bool isLoaded() const { return _loaded; }
+
+	CJKLang lang() const { return _lang; }
+	void setLang(CJKLang l) { _lang = l; }
+	void cycleLang();             // Orig -> ZH -> (Orig)  [JA reserved]
+	bool active() const { return _loaded && _lang != kCJKLangOrig; }
+
+	// Layout metrics are in the 320x200 virtual-screen space; the bitmap font is
+	// stored at 2x (24px) for crisp rendering, so layout uses half the glyph size.
+	int fontHeight() const { return _h / 2; }
+
+	// Translated string (Big5 bytes) for a dialog slot, or nullptr.
+	const Common::String *lookupDialog(int sceneNum, int dlgNum) const;
+
+	// Translated UI string keyed by its English source text ("UI:<src>"), or nullptr.
+	const Common::String *lookupUI(const Common::String &englishSrc) const;
+
+	// Wrap a Big5 string to maxWidth pixels (every full-width char is a break point;
+	// '\r' forces a newline). ASCII runs measured with asciiFont.
+	void wrapText(const Common::String &big5, int maxWidth,
+	              Common::StringArray &lines, const DgdsFont *asciiFont) const;
+
+	// Pixel width of a Big5 string (CJK=_w each, ASCII via asciiFont).
+	int stringWidth(const Common::String &big5, const DgdsFont *asciiFont) const;
+
+	// Record a wrapped line to draw later (coords in 320x200 virtual space). The actual
+	// crisp 24x24 draw happens in flushDeferred() during the 2x present.
+	void deferLine(int x, int y, int w, uint32 color, const Common::String &big5,
+	               Graphics::TextAlign align, const DgdsFont *asciiFont);
+	void clearDeferred() { _deferred.clear(); }
+	void flushDeferred(Graphics::ManagedSurface *dst640);
+
+private:
+	bool loadFont(const Common::String &fontFile);
+	bool loadTranslations(const Common::String &trnFile);
+	const byte *glyphPtr(int idx) const;
+	void drawGlyph(Graphics::ManagedSurface *dst, int idx, int x, int y, uint32 color) const;
+
+	bool _loaded;
+	CJKLang _lang;
+
+	// font
+	byte _w, _h, _bpr;
+	uint32 _numGlyphs;
+	byte *_glyphs;
+
+	// translations: key "<scene>:<dlg>" -> Big5 string
+	Common::HashMap<Common::String, Common::String> _dialogs;
+
+	// deferred hi-res text lines (320x200 coords), flushed at 24x24 during present2x
+	struct DeferredLine {
+		Common::String text;
+		int x, y, w;
+		uint32 color;
+		Graphics::TextAlign align;
+		const DgdsFont *asciiFont;
+	};
+	Common::Array<DeferredLine> _deferred;
+};
+
+} // namespace Dgds
+
+#endif
