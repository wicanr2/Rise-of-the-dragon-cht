@@ -553,6 +553,28 @@ void Dialog::drawForeground(Graphics::ManagedSurface *dst, uint16 fontcol, const
 	// For now do the simplest wrapping, no highlighting.
 	assert(_state);
 
+	// ROTD CHT: if a translation exists for this dialog slot, draw it with the Big5 font.
+	{
+		DgdsEngine *engine = DgdsEngine::getInstance();
+		CJKSupport &cjk = engine->getCJK();
+		if (cjk.active() && engine->getScene()) {
+			const Common::String *zh = cjk.lookupDialog(engine->getScene()->getNum(), _num);
