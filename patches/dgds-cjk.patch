new file mode 100644
index 00000000..8588503a
--- /dev/null
+++ b/engines/dgds/cjk.cpp
@@ -0,0 +1,200 @@
+/* ScummVM dgds CJK localization support (Rise of the Dragon CHT). Non-upstream. */
+
+#include "common/file.h"
+#include "common/debug.h"
+#include "dgds/cjk.h"
+#include "dgds/font.h"
+
+namespace Dgds {
+
+int big5LinearIndex(byte lead, byte trail) {
+	int to;
+	if (trail >= 0x40 && trail <= 0x7E)
+		to = trail - 0x40;          // 0..62
+	else if (trail >= 0xA1 && trail <= 0xFE)
+		to = 63 + (trail - 0xA1);   // 63..156
+	else
+		return -1;
+	if (lead < 0x81 || lead > 0xFE)
+		return -1;
+	return (lead - 0x81) * 157 + to;
+}
+
+static inline bool isBig5Lead(byte b) { return b >= 0x81 && b <= 0xFE; }
+
+CJKSupport::CJKSupport()
+	: _loaded(false), _lang(kCJKLangZH), _w(0), _h(0), _bpr(0), _numGlyphs(0), _glyphs(nullptr) {}
+
+CJKSupport::~CJKSupport() { delete[] _glyphs; }
+
+bool CJKSupport::load(const Common::String &fontFile, const Common::String &trnFile) {
+	bool okFont = loadFont(fontFile);
+	bool okTrn = loadTranslations(trnFile);
+	_loaded = okFont; // translations optional; font required
+	debug(1, "CJKSupport::load font=%d trn=%d (%d dialogs)", okFont, okTrn, (int)_dialogs.size());
+	return _loaded;
+}
+
+bool CJKSupport::loadFont(const Common::String &fontFile) {
+	Common::File f;
+	if (!f.open(Common::Path(fontFile))) {
+		warning("CJK: font %s not found", fontFile.c_str());
+		return false;
+	}
+	char magic[4];
+	f.read(magic, 4);
+	if (memcmp(magic, "DCJK", 4)) { warning("CJK: bad font magic"); return false; }
+	f.readByte();              // version
+	_w = f.readByte();
+	_h = f.readByte();
+	_bpr = f.readByte();
+	f.readByte();              // encoding
+	f.readByte(); f.readByte(); // pad
+	_numGlyphs = f.readUint32LE();
+	uint32 bytes = _numGlyphs * _bpr * _h;
+	_glyphs = new byte[bytes];
+	uint32 got = f.read(_glyphs, bytes);
+	if (got != bytes) { warning("CJK: short font read %u/%u", got, bytes); return false; }
+	debug(1, "CJK font %dx%d bpr=%d glyphs=%d", _w, _h, _bpr, _numGlyphs);
+	return true;
+}
+
+bool CJKSupport::loadTranslations(const Common::String &trnFile) {
+	Common::File f;
+	if (!f.open(Common::Path(trnFile)))
+		return false;
+	char magic[4];
+	f.read(magic, 4);
+	if (memcmp(magic, "DTRN", 4)) { warning("CJK: bad trn magic"); return false; }
+	f.readByte();               // version
+	f.readByte();               // lang
+	f.readByte(); f.readByte();  // pad
+	uint32 count = f.readUint32LE();
+	for (uint32 i = 0; i < count; i++) {
+		uint16 klen = f.readUint16LE();
+		Common::String key;
+		for (uint16 k = 0; k < klen; k++) key += (char)f.readByte();
+		uint16 vlen = f.readUint16LE();
+		Common::String val;
+		for (uint16 v = 0; v < vlen; v++) val += (char)f.readByte();
+		_dialogs[key] = val;
+	}
+	return true;
+}
+
+void CJKSupport::cycleLang() {
+	_lang = (_lang == kCJKLangOrig) ? kCJKLangZH : kCJKLangOrig;
+}
+
+const Common::String *CJKSupport::lookupDialog(int sceneNum, int dlgNum) const {
+	Common::String key = Common::String::format("%d:%d", sceneNum, dlgNum);
+	if (!_dialogs.contains(key))
+		return nullptr;
+	return &_dialogs[key];
+}
+
+const Common::String *CJKSupport::lookupUI(const Common::String &englishSrc) const {
+	Common::String s = englishSrc;
+	s.trim(); // normalize leading/trailing spaces (headers carry a leading space)
+	Common::String key = Common::String("UI:") + s;
+	if (!_dialogs.contains(key))
+		return nullptr;
+	return &_dialogs[key];
+}
+
+const byte *CJKSupport::glyphPtr(int idx) const {
+	if (idx < 0 || (uint32)idx >= _numGlyphs) return nullptr;
+	return _glyphs + (uint32)idx * _bpr * _h;
+}
+
+void CJKSupport::drawGlyph(Graphics::ManagedSurface *dst, int idx, int x, int y, uint32 color) const {
+	const byte *g = glyphPtr(idx);
+	if (!g) return;
+	byte *base = (byte *)dst->getBasePtr(0, 0);
+	int pitch = dst->pitch;
+	for (int ry = 0; ry < _h; ry++) {
+		int ty = y + ry;
+		if (ty < 0 || ty >= dst->h) continue;
+		const byte *row = g + ry * _bpr;
+		for (int cx = 0; cx < _w; cx++) {
+			int tx = x + cx;
+			if (tx < 0 || tx >= dst->w) continue;
+			if (row[cx >> 3] & (0x80 >> (cx & 7)))
+				base[ty * pitch + tx] = (byte)color;
+		}
+	}
+}
+
+int CJKSupport::stringWidth(const Common::String &s, const DgdsFont *asciiFont) const {
+	int w = 0;
+	uint i = 0;
+	while (i < s.size()) {
+		byte b = (byte)s[i];
+		if (isBig5Lead(b) && i + 1 < s.size() && big5LinearIndex(b, (byte)s[i + 1]) >= 0) {
+			w += _w; i += 2;
+		} else {
+			if (b != '\r' && asciiFont) w += asciiFont->getCharWidth(b);
+			i += 1;
+		}
+	}
+	return w;
+}
+
+void CJKSupport::wrapText(const Common::String &s, int maxWidth,
+                          Common::StringArray &lines, const DgdsFont *asciiFont) const {
+	lines.clear();
+	Common::String cur;
+	int curw = 0;
+	uint i = 0;
+	while (i < s.size()) {
+		byte b = (byte)s[i];
+		if (b == '\r') {
+			lines.push_back(cur); cur.clear(); curw = 0; i += 1; continue;
+		}
+		Common::String unit;
+		int uw;
+		if (isBig5Lead(b) && i + 1 < s.size() && big5LinearIndex(b, (byte)s[i + 1]) >= 0) {
+			unit += (char)b; unit += s[i + 1]; uw = _w; i += 2;
+		} else {
+			unit += (char)b; uw = asciiFont ? asciiFont->getCharWidth(b) : 6; i += 1;
+		}
+		if (maxWidth > 0 && curw + uw > maxWidth && !cur.empty()) {
+			lines.push_back(cur); cur.clear(); curw = 0;
+		}
+		cur += unit; curw += uw;
+	}
+	if (!cur.empty() || lines.empty())
+		lines.push_back(cur);
+}
+
+void CJKSupport::drawString(Graphics::ManagedSurface *dst, const Common::String &s,
+                            int x, int y, int w, uint32 color,
+                            Graphics::TextAlign align, const DgdsFont *asciiFont) const {
+	int sw = stringWidth(s, asciiFont);
+	int xcur = x;
+	if (align == Graphics::kTextAlignCenter)
+		xcur = x + (w - sw) / 2;
+	else if (align == Graphics::kTextAlignRight)
+		xcur = x + (w - sw);
+
+	uint i = 0;
+	while (i < s.size()) {
+		byte b = (byte)s[i];
+		if (isBig5Lead(b) && i + 1 < s.size()) {
+			int idx = big5LinearIndex(b, (byte)s[i + 1]);
+			if (idx >= 0) {
+				drawGlyph(dst, idx, xcur, y, color);
+				xcur += _w; i += 2; continue;
+			}
+		}
+		if (b != '\r') {
+			if (asciiFont) {
+				asciiFont->drawChar(dst, b, xcur, y, color);
+				xcur += asciiFont->getCharWidth(b);
+			}
+		}
+		i += 1;
+	}
+}
+
+} // namespace Dgds
