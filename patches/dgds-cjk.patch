+				debug(1, "CJK dialog %d:%d -> %s", engine->getScene()->getNum(), _num, zh->c_str());
+				const DgdsFont *afont = getDlgTextFont();
+				const int lh = cjk.fontHeight() + 1;
+				Common::StringArray zlines;
+				cjk.wrapText(*zh, _state->_loc.width, zlines, afont);
+				int ystart = _state->_loc.y + (_state->_loc.height - (int)zlines.size() * lh) / 2;
+				Graphics::TextAlign al = hasFlag(kDlgFlagLeftJust) ? Graphics::kTextAlignLeft : Graphics::kTextAlignCenter;
+				for (uint zi = 0; zi < zlines.size(); zi++)
+					cjk.drawString(dst, zlines[zi], _state->_loc.x, ystart + zi * lh,
+					               _state->_loc.width, fontcol, al, afont);
+				return;
+			}
+		}
+	}
+
 	Common::StringArray lines;
 	const DgdsFont *font = getDlgTextFont();
 	const int h = font->getFontHeight();
